# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

#--------------------------------------------------------------------
# Database (MySQL – use with docker compose)
#--------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=betalent
DB_PASSWORD=betalent_pass
DB_DATABASE=betalent_db

#--------------------------------------------------------------------
# Gateways mock (BeTalent)
#--------------------------------------------------------------------
GATEWAY1_URL=http://localhost:3001
GATEWAY2_URL=http://localhost:3002

#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000