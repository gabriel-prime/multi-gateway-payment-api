# Node
TZ=UTC
PORT=3333
HOST=0.0.0.0
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

#--------------------------------------------------------------------
# Database (MySQL – use with docker compose)
#--------------------------------------------------------------------
DB_HOST=mysql
DB_PORT=3306
DB_USER=betalent
DB_PASSWORD=betalent_pass
DB_DATABASE=betalent_db

# Para rodar a API fora do Docker, use:
# DB_HOST=127.0.0.1

#--------------------------------------------------------------------
# Gateway 1 (http://localhost:3001 fora do Docker)
# Autenticação: POST /login com email + token (32 chars)
#--------------------------------------------------------------------
GATEWAY1_URL=http://gateways-mock:3001
GATEWAY1_EMAIL=dev@betalent.tech
GATEWAY1_TOKEN=FEC9BB078BF338F464F96B48089EB498

#--------------------------------------------------------------------
# Gateway 2 (http://localhost:3002 fora do Docker)
# Autenticação: headers fixos Gateway-Auth-Token e Gateway-Auth-Secret
#--------------------------------------------------------------------
GATEWAY2_URL=http://gateways-mock:3002
GATEWAY2_AUTH_TOKEN=tk_f2198cc671b5289fa856
GATEWAY2_AUTH_SECRET=3d15e8ed6131446ea7e3456728b1211f

